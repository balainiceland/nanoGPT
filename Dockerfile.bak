FROM python:3.11-slim AS builder

WORKDIR /build

# Download and install torch wheel separately (cacheable layer)
RUN pip install --no-cache-dir --target=/deps \
    torch==2.5.1+cpu --index-url https://download.pytorch.org/whl/cpu

# Install remaining deps
RUN pip install --no-cache-dir --target=/deps \
    numpy tiktoken fastapi "uvicorn[standard]" openai anthropic supabase httpx

# --- Final slim image ---
FROM python:3.11-slim

WORKDIR /app

# Copy pre-built deps from builder
COPY --from=builder /deps /usr/local/lib/python3.11/site-packages/

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

COPY model.py serve.py configurator.py rag.py ./

RUN mkdir -p out-pelagic && chown -R appuser:appuser /app

ENV PYTHONUNBUFFERED=1
ENV PELAGIC_DEVICE=cpu
ENV PELAGIC_CHECKPOINT_DIR=out-pelagic

USER appuser
EXPOSE 8000

CMD ["sh", "-c", "exec uvicorn serve:app --host 0.0.0.0 --port ${PORT:-8000}"]
